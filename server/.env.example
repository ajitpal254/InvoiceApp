## Environment Variables
## Copy this file to .env and fill in the values

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/InvoiceApp
PORT=5000
JWT_SECRET=your_jwt_secret_here
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@smtp-brevo.com
SMTP_PASS=your_smtp_password
SMTP_KEY=your_brevo_smtp_key
SMTP_FROM=your_verified_sender@yourdomain.com
FRONTEND_URL=https://ouvrabilling.netlify.app
